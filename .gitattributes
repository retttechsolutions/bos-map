# Git LFS for large binary/geodata files
data/raw/**/*.zip filter=lfs diff=lfs merge=lfs -text
data/raw/**/*.gdb filter=lfs diff=lfs merge=lfs -text
data/raw/**/*.geojson filter=lfs diff=lfs merge=lfs -text
data/raw/**/*.gpkg filter=lfs diff=lfs merge=lfs -text
data/raw/**/*.shp filter=lfs diff=lfs merge=lfs -text
data/raw/**/*.dbf filter=lfs diff=lfs merge=lfs -text
data/raw/**/*.xml filter=lfs diff=lfs merge=lfs -text

# Processed files can be large too
data/processed/ils.geojson filter=lfs diff=lfs merge=lfs -text

# Normalise line endings
*.py text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
